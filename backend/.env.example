# Copy this file to .env and fill in your values

# Generate a long random string for this — e.g. run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Local SQLite (default). On Railway, set this to your PostgreSQL URL automatically.
DATABASE_URL=sqlite:///./betlobby.db

# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Your frontend URL (used for Stripe redirect after payment)
FRONTEND_URL=http://localhost:5173
